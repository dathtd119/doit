# Copy to ~/.grok/config.toml model env keys or export as needed.
# Never commit real secrets.

# Model / provider (names match do-harness/config.models.yaml examples)
# EXAMPLE_API_KEY=
# XAI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Stock grok discovery home (optional; default ~/.grok)
# GROK_HOME=

# Error tracking (optional local override)
# SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# Product analytics (optional) — product default is OFF (do-harness/config.defaults.toml).
# Prefer TOML: [features] telemetry = false; [telemetry] trace_upload/mixpanel_enabled = false.
# MIXPANEL_TOKEN=
