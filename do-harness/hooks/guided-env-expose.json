{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^(Bash|bash|run_terminal_command|run_terminal_cmd|Shell|shell)$",
        "hooks": [
          {
            "type": "command",
            "command": "bin/guided-env-expose.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
