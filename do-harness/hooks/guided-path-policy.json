{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^(write|Write|search_replace|SearchReplace|str_replace|StrReplace|edit|Edit|create|Create|apply_patch|ApplyPatch|MultiEdit|hashline_edit|hashline_write|Bash|bash|run_terminal_command|run_terminal_cmd|Shell|shell)$",
        "hooks": [
          {
            "type": "command",
            "command": "bin/guided-path-policy.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
