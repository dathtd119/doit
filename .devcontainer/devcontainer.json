{
  "name": "do (Rust agent harness)",
  "image": "mcr.microsoft.com/devcontainers/rust:1-1-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "vadimcn.vscode-lldb",
        "github.vscode-github-actions"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "rust-analyzer.check.command": "clippy"
      }
    }
  },
  "postCreateCommand": "rustup component add rustfmt clippy && cargo --version && (command -v pre-commit >/dev/null || pipx install pre-commit || pip install --user pre-commit) && bash scripts/validate-agents-md.sh",
  "forwardPorts": [],
  "remoteUser": "vscode",
  "containerEnv": {
    "CARGO_TERM_COLOR": "always"
  }
}
